// Variáveis de controle do joguinho da semente
let cliquesAgua = 0;
let pontosSol = 0;
let evolucao = 0; // 0 = semente, 1 = broto, 2 = árvore floridona

const emojiPlanta = document.getElementById('estagio-planta');
const statusPlanta = document.getElementById('status-planta');
const painelSol = document.getElementById('pontos-sol');

function regar() {
    if (evolucao === 0) {
        cliquesAgua++;
        statusPlanta.innerText = `Você jogou água! Ela precisa de mais ${3 - cliquesAgua} goles para brotar.`;
        verificarEvolucao();
    } else if (evolucao === 1) {
        statusPlanta.innerText = "O brotinho adorou a água! Dê um pouco de Sol para ele crescer.";
    } else {
        statusPlanta.innerText = "Sua árvore está gigante e super hidratada! 🌳✨";
    }
}

function darSol() {
    pontosSol += 10;
    painelSol.innerText = pontosSol;
    
    if (evolucao === 1 && pontosSol >= 30) {
        evolucao = 2;
        emojiPlanta.innerText = "🌳";
        statusPlanta.innerText = "Parabéns! Com o poder do Sol e da água, você cultivou uma árvore do futuro cheia de frutos!";
    } else if (evolucao === 0) {
        statusPlanta.innerText = "Solzinho gostoso, mas a semente ainda precisa de água para abrir.";
    } else if (evolucao === 1) {
        statusPlanta.innerText = `O broto está fazendo fotossíntese. (Pontos de Sol atuais: ${pontosSol}/30)`;
    }
}

function conversar() {
    const frases = [
        "A planta sussurrou: 'Obrigado por cuidar do amanhã!' 💚",
        "Ela balançou as folhas alegremente! 🍃",
        "Sabia que plantas crescem melhor com música e carinho? 🎵",
        "Ela disse que o futuro do planeta está em boas mãos! 🌍"
    ];
    // Sorteia uma frase divertida para mostrar na tela
    const fraseAleatoria = frases[Math.floor(Math.random() * frases.length)];
    statusPlanta.innerText = fraseAleatoria;
}

function verificarEvolucao() {
    if (cliquesAgua >= 3 && evolucao === 0) {
        evolucao = 1;
        emojiPlanta.innerText = "🌿";
        statusPlanta.innerText = "Uau! A semente rompeu a terra e virou um broto forte! Agora ela precisa de 30 pontos de Sol.";
    }
}


function atualizarGuia() {
    const seletor = document.getElementById('escolha-semente');
    const valorSelecionado = seletor.value;
    
    const painel = document.getElementById('painel-instrucoes');
    const elementoIlustra = document.getElementById('ilustra-passo');
    const elementoTitulo = document.getElementById('titulo-passo');
    const elementoLista = document.getElementById('lista-passos');

    // Se o usuário não selecionou nenhuma semente válida, esconde o painel
    if (!valorSelecionado) {
        painel.classList.add('escondido');
        return;
    }

    // Busca os dados no objeto baseado na semente escolhida
    const dadosPlanta = guiasCultivo[valorSelecionado];

    // Atualiza a tela com animação e textos limpos
    elementoIlustra.innerText = dadosPlanta.icone;
    elementoTitulo.innerText = dadosPlanta.titulo;
    
    // Limpa a lista antiga para construir a nova
    elementoLista.innerHTML = "";
    
    // Varre os passos e cria elementos <li> para cada um
    dadosPlanta.passos.forEach(passo => {
        const itemLista = document.createElement('li');
        itemLista.innerText = passo;
        elementoLista.appendChild(itemLista);
    });

    // Exibe o painel atualizado
    painel.classList.remove('escondido');
}

